# Copy this file to gateway/.env.local, fill in your own key, then protect it:
# cp gateway/.env.local.example gateway/.env.local
# chmod 600 gateway/.env.local
# Do not paste this key into the desktop app, project JSON, issue trackers, or logs.
GATEWAY_SESSION_SECRET="replace-with-at-least-32-random-characters"
OPENAI_API_KEY="replace-with-your-own-openai-api-key"
OPENAI_MODEL="gpt-5.6"
GEMINI_API_KEY="replace-with-your-own-gemini-api-key"
GEMINI_MODEL="gemini-flash-lite-latest"
GATEWAY_ALLOWED_ORIGIN="http://localhost:1420"
# Default only. The desktop user can select any configured OpenAI or Gemini provider.
GATEWAY_MODEL_PROVIDER="openai"
