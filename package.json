{
  "name": "ai-music-ide",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24.14.0 <26.0.0",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc -b && vite build",
    "gateway:build": "tsc -p gateway/tsconfig.json",
    "gateway:start": "node gateway/dist/main.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write \"{src,gateway/src}/**/*.{ts,tsx,json}\" \"*.{js,json,ts,tsx}\"",
    "format:check": "prettier --check \"{src,gateway/src}/**/*.{ts,tsx,json}\" \"*.{js,json,ts,tsx}\"",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-fs": "^2.4.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tone": "15.1.22",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.8.4",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^10.7.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.9.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
