{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI Music IDE",
  "version": "0.1.0",
  "identifier": "com.aimusicide.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "AI Music IDE",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": [
          "'self'",
          "customprotocol:",
          "asset:"
        ],
        "connect-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "ipc:",
          "http://ipc.localhost"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "data:"
        ],
        "media-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "data:"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "script-src": [
          "'self'"
        ]
      },
      "devCsp": {
        "default-src": [
          "'self'"
        ],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://localhost:1420",
          "ws://localhost:1420"
        ],
        "img-src": [
          "'self'",
          "asset:",
          "http://asset.localhost",
          "blob:",
          "data:"
        ],
        "style-src": [
          "'self'",
          "'unsafe-inline'"
        ],
        "script-src": [
          "'self'"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
